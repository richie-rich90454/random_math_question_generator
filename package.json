{
  "name": "random_math_question_generator",
  "version": "3.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start": "go run main.go",
    "build:typescript": "tsc --noEmit",
    "build:web": "vite build",
    "build": "npm run build:typescript && npm run build:web",
    "build:go": "go build -o server main.go",
    "start:nodejs": "vite preview",
    "test": "vitest",
    "test:coverage": "vitest --coverage"
  },
  "keywords": [
    "math",
    "calculus",
    "precalculus",
    "algebra",
    "integration",
    "differentiation"
  ],
  "author": "richie-rich90454",
  "license": "Apache-2.0",
  "dependencies": {
    "mathjax": "^4.1.1",
    "mathjs": "^15.1.1",
    "path": "^0.12.7",
    "three": "^0.183.2"
  },
  "description": "Random math question generator made with HTML, CSS, and TS.",
  "devDependencies": {
    "@types/mathjs": "^9.4.2",
    "@types/node": "^25.5.0",
    "@types/three": "^0.183.1",
    "jsdom": "^29.0.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.5",
    "vitest": "^4.1.2"
  }
}
